<div class="app-container">

    <div class="sidebar">
        <!-- SWITCH MODERNO -->
        <div class="switch-container">
            <div class="switch-slider"></div>

            <div class="switch-option active"
                 data-url="/Methods/Closed"
                 data-index="0">
                Métodos cerrados
            </div>

            <div class="switch-option"
                 data-url="/Methods/Open"
                 data-index="1">
                Métodos abiertos
            </div>
        </div>

        <!-- CONTENIDO DINÁMICO -->
        <div id="methods-container">
            @Html.Partial("_ClosedMethods")
        </div>
    </div>
    <!-- PANEL DERECHO -->
    <div class="main-panel">

        <!-- TARJETA DE RESULTADOS -->
        <div class="result-card">

            <div class="result-header">
                <h3>Bisección</h3>
                <div id="res-function" class="equation">f(x)=x+5</div>
            </div>

            <div class="result-body">
                <div class="result-row">
                    <strong>Resultados:</strong>
                </div>

                <div class="result-row">
                    <span>Iteraciones</span>
                    <strong id="res-iterations">-</strong>
                </div>

                <div class="result-row">
                    <span>Error relativo</span>
                    <strong id="res-error">-</strong>
                </div>

                <div class="result-row highlight">
                    <span>Raíz</span>
                    <strong id="res-root">-</strong>
                </div>

                <div class="result-footer">
                    <span id="res-interval">Intervalo: -</span>
                    <span id="res-tolerance">Tolerancia: -</span>
                </div>
            </div>

        </div>

        <!-- GRÁFICO -->
        <div class="graph-card">           
            <div class="graph-placeholder">
                <div id="ggb-element"></div>
            </div>
        </div>
    </div>
</div>

<script src="https://www.geogebra.org/apps/deployggb.js"></script>
<script src="~/js/switches.js" asp-append-version="true"></script>
<script src="~/js/form.js" asp-append-version="true"></script>
<script src="~/js/geogebra-bridge.js" asp-append-version="true"></script>
