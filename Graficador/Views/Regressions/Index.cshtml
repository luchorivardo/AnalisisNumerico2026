<div class="app-container">
    <div class="sidebar">
        <form id="regression-form" class="form">

            <div class="switch-container">
                <div class="switch-slider"></div>

                <div class="switch-option active"
                     data-method="linear"
                     data-index="0">
                    Lineal
                </div>

                <div class="switch-option"
                     data-method="polynomial"
                     data-index="1">
                    Polinomial
                </div>
            </div>

            <div class="form-group">
                <label>Ingresar Punto:</label>
                <div style="display: flex; gap: 10px; align-items: center; flex-direction: column;">
                    <input type="number" id="x-input" placeholder="X" step="any" style="flex: 1; width: 100% !important;">
                    <input type="number" id="y-input" placeholder="Y" step="any" style="flex: 1; width: 100% !important;">
                    <button type="button" id="btn-add-point" class="btn-secundary" style="padding: 8px 12px; width: 100% !important;">
                        Agregar
                    </button>
                </div>
            </div>

            <div class="form-group poly-only" style="display:none;">
                <label>Grado del polinomio</label>
                <input type="number" id="poly-degree" value="2" min="2" max="10">
            </div>

            <div class="form-group">
                <label>Tolerancia (ej: 0.8 para 80%)</label>
                <input type="number" id="tolerance" step="0.01" value="0.8" min="0" max="1">
            </div>

            <div class="form-group">
                <label>Puntos Ingresados:</label>
                <select id="points-list" multiple size="6"></select>

                <div style="display: flex; gap: 10px; margin-top: 10px;">
                    <button type="button" id="btn-delete-selected" class="btn-secundary" style="flex: 2;">ELIMINAR SELECCIÓN</button>
                    <button type="button" id="btn-delete-all" class="btn-secundary" style="flex: 1.5;">BORRAR TODOS</button>
                </div>
            </div>

            <button type="submit" class="btn-primary" style="margin-top: 10px;">
                Calcular Regresión
            </button>
        </form>
    </div>

    <div class="main-panel">

        <div class="result-card">
            <div class="result-header">
                <h3 id="result-title">Regresión Lineal</h3>
            </div>

            <div class="result-body">
                <div class="result-row">
                    <strong>Datos de Salida:</strong>
                </div>

                <div class="result-row highlight">
                    <span>Función Obtenida</span>
                    <strong id="res-function">-</strong>
                </div>

                <div class="result-row">
                    <span>Correlación (r)</span>
                    <strong id="res-correlation">-</strong>
                </div>

                <div class="result-row">
                    <span>Efectividad del Ajuste</span>
                    <strong id="res-effectiveness">-</strong>
                </div>
            </div>
        </div>

        <div class="graph-card">
            <div class="graph-placeholder">
                <div id="ggb-element"></div>
            </div>
        </div>
    </div>
</div>

<script src="https://www.geogebra.org/apps/deployggb.js"></script>
<script src="~/js/regression.js" asp-append-version="true"></script>