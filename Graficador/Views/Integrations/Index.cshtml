<div class="app-container">
    <div class="sidebar">
        <form id="integration-form" class="form">
            <h3 style="margin-bottom: 20px; color: white;">Integración Numérica</h3>

            <div class="form-group">
                <label>F(x):</label>
                <input type="text" id="fx-input" placeholder="ej: x^2 - 4" required>
            </div>

            <div class="form-group">
                <label>Límites:</label>
                <div style="display: flex; gap: 10px;">
                    <input type="number" id="xi-input" placeholder="Xi (a)" step="any" required>
                    <input type="number" id="xd-input" placeholder="Xd (b)" step="any" required>
                </div>
            </div>

            <div class="form-group">
                <label>Cantidad de subintervalos (n):</label>
                <input type="number" id="n-input" min="1" placeholder="Solo para múltiples">
            </div>

            <div class="form-group">
                <label>Método:</label>
                <select id="method-select" style="width: 100%; padding: 8px;">
                    <option value="trapecios_simple">Trapecios Simple</option>
                    <option value="trapecios_multiple">Trapecios Múltiple</option>
                    <option value="simpson_13_simple">Simpson 1/3 Simple</option>
                    <option value="simpson_13_multiple">Simpson 1/3 Múltiple</option>
                    <option value="simpson_38">Simpson 3/8</option>
                    <option value="simpson_combinado">Simpson Combinado (Impares)</option>
                </select>
            </div>

            <button type="submit" class="btn-primary" style="margin-top: 10px;">
                Calcular
            </button>
        </form>
    </div>

    <div class="main-panel">
        <div class="result-card">
            <div class="result-header">
                <h3>Resultado</h3>
            </div>
            <div class="result-body">
                <div class="result-row highlight">
                    <span>Área:</span>
                    <strong id="res-area">-</strong>
                </div>
            </div>
        </div>

        <div class="graph-card">
            <div class="graph-placeholder">
                <div id="ggb-element"></div>
            </div>
        </div>
    </div>
</div>

<script src="https://www.geogebra.org/apps/deployggb.js"></script>
<script src="~/js/integration.js" asp-append-version="true"></script>